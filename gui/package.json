{
  "name": "aegiscore-gui",
  "version": "1.0.0",
  "description": "AegisCore Antivirus GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.aegiscore.gui",
    "productName": "AegisCore",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "*.html",
      "main.js",
      "preload.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
