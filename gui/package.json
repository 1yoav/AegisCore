{
  "name": "aegiscore-gui",
  "version": "1.0.0",
  "description": "AegisCore Antivirus GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.aegiscore.gui",
    "productName": "AegisCore",
    "npmRebuild": true,
    "win": {
      "target": "dir",
      "icon": "assets/icon.ico"
    },
    "files": [
      "*.html",
      "main.js",
      "preload.js",
      "assets/**",
      "node_modules/**"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "sqlite3": "^6.0.1"
  }
}
